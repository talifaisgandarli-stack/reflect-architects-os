VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram webhook secret — protects /api/telegram from spoofed POSTs.
# Generate a strong random string (≥32 chars) and re-run ?action=setWebhook
# after setting this so Telegram knows to send the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=

# Shared secret for /api/agent cron / scheduled jobs.
# On Vercel: name this `CRON_SECRET` and Vercel cron jobs will send the
# `Authorization: Bearer <CRON_SECRET>` header automatically — no URL changes needed.
# Manual triggers can also pass `?secret=<value>` as a query param.
CRON_SECRET=

# Gemini API key (used by /api/agent for AI features)
GEMINI_API_KEY=
