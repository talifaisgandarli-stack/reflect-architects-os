VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram webhook secret — protects /api/telegram from spoofed POSTs.
# Generate a strong random string (≥32 chars) and re-run ?action=setWebhook
# after setting this so Telegram knows to send the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=

# Shared secret for /api/agent cron / scheduled jobs.
# Pass as `Authorization: Bearer <secret>` or `?secret=<secret>` query param.
AGENT_CRON_SECRET=

# Gemini API key (used by /api/agent for AI features)
GEMINI_API_KEY=
