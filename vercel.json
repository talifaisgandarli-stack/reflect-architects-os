{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/agent?type=morning",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/agent?type=morning_admin",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/agent?type=outsource_deadline",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/agent?type=nicat_events",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/agent?type=deadline_warning",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/agent?type=evening",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/agent?type=weekly_report",
      "schedule": "0 13 * * 5"
    }
  ]
}